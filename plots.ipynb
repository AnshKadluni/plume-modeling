import numpy as np
if not hasattr(np, "trapezoid"):
    np.trapezoid = np.trapz
import matplotlib.pyplot as plt
from scipy.stats import norm
from scipy.integrate import cumulative_trapezoid

plt.rcParams.update({
    'font.family': 'serif', 'font.size': 11,
    'axes.spines.top': False, 'axes.spines.right': False,
    'axes.grid': True, 'grid.alpha': 0.25, 'grid.linestyle': '--',
    'figure.dpi': 150
})

SWI     = 0.20      # initial water saturation
SGR     = 0.00      # residual gas saturation
LAM     = 2.0       # Brooks-Corey pore-size index (lambda)
N_EXP   = 2.0       # Brooks-Corey relative-permeability exponent (n)
KRG_MAX = 1.0       # maximum gas relative permeability
PD_PM   = 5.0       # p_d / p_m 
C_CONST = PD_PM - 1.0          # B0 = c / H_cD

MU_MEAN = 0.50
SIGMA   = 0.30
KMIN    = 0.05
KMAX    = 1.00     

def k_D(zD, mu_mean=MU_MEAN, sigma=SIGMA, kmin=KMIN, kmax=KMAX):
    A = norm.cdf((kmin - mu_mean) / sigma)
    B = norm.cdf((kmax - mu_mean) / sigma)
    arg = np.clip(B - (B - A) * np.asarray(zD), 1e-9, 1 - 1e-9)
    k = mu_mean + sigma * norm.ppf(arg)
    return np.clip(k, kmin, kmax) / kmax

def _swe_fringe(zD, hD, HcD, lam=LAM, c=C_CONST):
    B0 = c / HcD
    pc_ratio = 1.0 + B0 * np.clip(hD - zD, 0.0, None)      # p_c / p_m
    return (1.0 / pc_ratio) ** lam

def s_g(zD, hD, HcD, swi=SWI, sgr=SGR, lam=LAM, c=C_CONST):
    zD = np.asarray(zD, dtype=float)
    in_fringe = zD >= (hD - HcD)            
    swe = _swe_fringe(zD, hD, HcD, lam, c)
    sg_fringe = 1.0 - swi - (1.0 - swi - sgr) * swe
    sg_pure   = (1.0 - swi) * np.ones_like(zD)             # pure-gas zone
    return np.where(in_fringe, sg_fringe, sg_pure)

def k_rg(zD, hD, HcD, n=N_EXP, krg_max=KRG_MAX, lam=LAM, c=C_CONST):
    zD = np.asarray(zD, dtype=float)
    in_fringe = zD >= (hD - HcD)
    swe = _swe_fringe(zD, hD, HcD, lam, c)
    sge = np.clip(1.0 - swe, 0.0, 1.0)
    krg_fringe = krg_max * sge ** n
    krg_pure   = krg_max * np.ones_like(zD)
    return np.where(in_fringe, krg_fringe, krg_pure)

def _zgrid(hD, HcD, npts=400):
    if hD <= HcD:                        
        return np.linspace(0.0, hD, npts)
    z_split = hD - HcD
    n1 = max(int(npts * z_split / hD), 30)        # pure-gas part
    n2 = npts - n1                                # fringe part
    z1 = np.linspace(0.0, z_split, n1, endpoint=False)
    z2 = np.linspace(z_split, hD, n2)
    return np.concatenate([z1, z2])

def M1D(hD, HcD, **kw):
    if hD <= 0: return 0.0
    zz = _zgrid(hD, HcD)
    return np.trapezoid(k_rg(zz, hD, HcD, **kw), zz)

def M2D(hD, HcD, **kw):
    if hD <= 0: return 0.0
    zz = _zgrid(hD, HcD)
    return np.trapezoid(k_D(zz) * k_rg(zz, hD, HcD, **kw), zz)


def build_F_G(hD_grid, gamma, HcD, mu=1.0, **kw):
    M1 = np.array([M1D(h, HcD, **kw) for h in hD_grid])
    M2 = np.array([M2D(h, HcD, **kw) for h in hD_grid])
    F  = mu * M1 + gamma * M2
    G  = cumulative_trapezoid(M2, hD_grid, initial=0.0)
    return F, G, M1, M2

hD = np.linspace(0, 1, 160)        
zD = np.linspace(0, 1, 400)

fig1, ax = plt.subplots(1, 3, figsize=(13, 4.2))

for sig, col in zip([0.20, 0.30, 0.50], ['#1f77b4', '#ff7f0e', '#2ca02c']):
    ax[0].plot(k_D(zD, sigma=sig), zD, lw=2, color=col, label=fr'$\sigma={sig}$')
ax[0].set_xlabel(r'$k_D(z_D)$'); ax[0].set_ylabel(r'$z_D$ (depth from seal)')
ax[0].set_title('(a) Permeability profile (truncated normal)')
ax[0].invert_yaxis(); ax[0].legend(fontsize=9)

for HcD, col in zip([0.1, 0.3, 0.5, 1.0], ['#d62728','#9467bd','#8c564b','#17becf']):
    ax[1].plot(s_g(zD, 1.0, HcD), zD, lw=2, color=col, label=fr'$H_{{cD}}={HcD}$')
    if HcD < 1.0:                                   # mark the regime split
        ax[1].axhline(1.0 - HcD, color=col, ls=':', lw=0.9, alpha=0.6)
ax[1].set_xlabel(r'$s_g(z_D)$'); ax[1].set_ylabel(r'$z_D$')
ax[1].set_title(r'(b) Gas saturation ($h_D=1$, piecewise)')
ax[1].invert_yaxis(); ax[1].legend(fontsize=9)

for HcD, col in zip([0.1, 0.3, 0.5, 1.0], ['#d62728','#9467bd','#8c564b','#17becf']):
    ax[2].plot(k_rg(zD, 1.0, HcD), zD, lw=2, color=col, label=fr'$H_{{cD}}={HcD}$')
    if HcD < 1.0:
        ax[2].axhline(1.0 - HcD, color=col, ls=':', lw=0.9, alpha=0.6)
ax[2].set_xlabel(r'$k_{rg}(z_D)$'); ax[2].set_ylabel(r'$z_D$')
ax[2].set_title(r'(c) Relative permeability ($h_D=1$, piecewise)')
ax[2].invert_yaxis(); ax[2].legend(fontsize=9)

fig1.tight_layout()
plt.show()
plt.close()

fig2, ax = plt.subplots(1, 2, figsize=(9.5, 4.2))

g0 = 1.0
for HcD, col in zip([0.1, 0.3, 0.5, 1.0], ['#d62728','#9467bd','#8c564b','#17becf']):
    F, G, _, _ = build_F_G(hD, g0, HcD)
    ax[0].plot(hD, F, lw=2, color=col, label=fr'$H_{{cD}}={HcD}$')
    ax[1].plot(hD, G, lw=2, color=col, label=fr'$H_{{cD}}={HcD}$')
    if HcD < 1.0:
        ax[0].axvline(HcD, color=col, ls=':', lw=0.8, alpha=0.6)
        ax[1].axvline(HcD, color=col, ls=':', lw=0.8, alpha=0.6)
ax[0].set_xlabel(r'$h_D$'); ax[0].set_ylabel(r'$F(h_D)$')
ax[0].set_title(r'(a) $F$ sweeping $H_{cD}$ ($\gamma=1$)')
ax[0].legend(fontsize=9)

ax[1].set_xlabel(r'$h_D$'); ax[1].set_ylabel(r'$G(h_D)$')
ax[1].set_title(r'(b) $G$ sweeping $H_{cD}$')
ax[1].legend(fontsize=9)

fig2.tight_layout()
plt.show()
plt.close()

fig3, ax = plt.subplots(1, 2, figsize=(9.5, 4.2))

a_ref = np.radians(10.0); g_ref, HcD_ref = 1.0, 0.3
for adeg, col in zip([5, 10, 20, 40, 60],
                     ['#1f77b4','#2ca02c','#d62728','#9467bd','#8c564b']):
    a = np.radians(adeg)
    g_a   = g_ref   * np.sin(a) / np.sin(a_ref)
    HcD_a = HcD_ref * np.cos(a_ref) / np.cos(a)
    F, G, _, _ = build_F_G(hD, g_a, HcD_a)
    ax[0].plot(hD, F, lw=2, color=col, label=fr'$\alpha={adeg}^\circ$')
    ax[1].plot(hD, G, lw=2, color=col, label=fr'$\alpha={adeg}^\circ$')
ax[0].set_xlabel(r'$h_D$'); ax[0].set_ylabel(r'$F(h_D)$')
ax[0].set_title(r'(a) $F$ sweeping dip $\alpha$')
ax[0].legend(fontsize=9)

ax[1].set_xlabel(r'$h_D$'); ax[1].set_ylabel(r'$G(h_D)$')
ax[1].set_title(r'(b) $G$ sweeping incline $\alpha$')
ax[1].legend(fontsize=9)

fig3.tight_layout()
plt.show()
plt.close()

fig4, ax = plt.subplots(1, 2, figsize=(9.5, 4.2))

HcD0 = 0.3
for g, col in zip([0.1, 0.5, 1.0, 2.0, 5.0],
                  ['#1f77b4','#2ca02c','#d62728','#9467bd','#8c564b']):
    F, _, _, _ = build_F_G(hD, g, HcD0)
    ax[0].plot(hD, F, lw=2, color=col, label=fr'$\gamma={g}$')
ax[0].axvline(HcD0, color='grey', ls=':', lw=1)
ax[0].annotate(r'$h_D=H_{cD}$', xy=(HcD0, 0.05), xytext=(HcD0+0.05, 0.4),
               fontsize=8, color='grey')
ax[0].set_xlabel(r'$h_D$'); ax[0].set_ylabel(r'$F(h_D)$')
ax[0].set_title(r'(a) $F$ sweeping $\gamma$  ($H_{cD}=0.3$)')
ax[0].legend(fontsize=9)

for mu_val, col in zip([0.5, 1, 2, 5, 10],
                        ['#1f77b4', '#2ca02c', '#d62728', '#9467bd', '#8c564b']):
    F, _, _, _ = build_F_G(hD, g_ref, HcD_ref, mu=mu_val)
    ax[1].plot(hD, F, lw=2, color=col, label=fr'$\mu={mu_val}$')
ax[1].set_xlabel(r'$h_D$'); ax[1].set_ylabel(r'$F(h_D)$')
ax[1].set_title(r'(b) $F$ sweeping viscosity ratio $\mu$  ($H_{cD}=0.3$, $\gamma=1$)')
ax[1].legend(fontsize=9)

fig4.tight_layout()
plt.show()
plt.close()

fig5, ax = plt.subplots(1, 1, figsize=(5.6, 4.2))

_, G_ref, _, _ = build_F_G(hD, g_ref, HcD_ref)
for eps, col in zip([0.01, 0.05, 0.1, 0.3],
                     ['#1f77b4', '#2ca02c', '#d62728', '#9467bd']):
    ax.plot(hD, eps * G_ref, lw=2, color=col, label=fr'$\varepsilon={eps}$')
ax.set_xlabel(r'$h_D$'); ax.set_ylabel(r'$\varepsilon\, G(h_D)$')
ax.set_title(r'Diffusion magnitude $\varepsilon\,G(h_D)$ vs $\varepsilon$  ($H_{cD}=0.3$)')
ax.legend(fontsize=9)

fig5.tight_layout()
plt.show()
plt.close()
